# Supabase — get these from `npx supabase start` (local) or your Supabase dashboard (hosted)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — required for AI board agents
OPENAI_API_KEY=sk-proj-your-openai-api-key

# Agent internal secret — any random 64-char hex string (openssl rand -hex 32)
AGENT_INTERNAL_SECRET=your-agent-secret

# E2E / load tests — optional
TEST_BOARD_JOIN_TOKEN=your-board-join-token
E2E_TEST_EMAIL=test@example.com
E2E_TEST_PASSWORD=your-test-password
E2E_TEST_BOARD_ID=uuid-of-board-owned-by-test-account

# Resend — email notifications for board invites
RESEND_API_KEY=re_your_resend_api_key

# Rich text editor — enables TipTap in-place editing for supported shape types
NEXT_PUBLIC_RICH_TEXT_ENABLED=true

# App URL — used for invite links, password reset redirect, and social meta tags
# In production, set to your deployed URL (e.g. https://www.theoremai.app)
# Add {NEXT_PUBLIC_APP_URL}/reset-password to Supabase Auth redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LangSmith — optional, enables AI agent tracing
# LANGSMITH_API_KEY=lsv2_pt_your-key
# LANGSMITH_PROJECT=collabboard-agent-mechanics
